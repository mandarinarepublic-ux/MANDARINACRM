GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google Sheets
SHEET_ID=15OeKiQH3y4PmY_nMQyJoDHZnpeMFFzCr

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_KEY=TU_API_KEY_AQUI

# Shopify - Mandarina
# TOKEN = Admin API access token (empieza con "shpat_").
# Se genera en: Shopify admin -> Settings -> Apps and sales channels ->
# Develop apps -> Create app -> API scopes: read_products -> Install -> copiar token.
SHOPIFY_MANDARINA_STORE=mandarinaec.myshopify.com
SHOPIFY_MANDARINA_TOKEN=shpat_TU_TOKEN_AQUI

# Shopify - Indstore (mismo procedimiento en el admin de Indstore)
SHOPIFY_INDSTORE_STORE=indlovers.myshopify.com
SHOPIFY_INDSTORE_TOKEN=shpat_TU_TOKEN_AQUI

# Sync de catálogo
# Secret que Vercel Cron envía como "Authorization: Bearer <CRON_SECRET>" al llamar
# a /api/shopify/sync. Genera uno largo y ponlo también en las env vars de Vercel.
CRON_SECRET=genera-un-secret-largo-aqui
# (Opcional) si el catálogo vive en otro spreadsheet distinto a SHEET_ID:
# PRODUCTOS_SHEET_ID=13MiI4BPE247suz539TtObvS3L0SqhMu5KnvIg2YkAfs

# Dátil (facturación electrónica)
# X-Key de tu cuenta Dátil. Se usa del lado servidor para descargar el RIDE (PDF)
# de la factura y mostrarlo en la app vía /api/factura/{id}/ride.
# Es la MISMA llave X-Key que usa el escenario de Make "VersionCORE".
DATIL_API_KEY=tu_x_key_de_datil_aqui
# (Opcional) solo si tu cuenta exige X-Password también para leer el RIDE:
# DATIL_API_PASSWORD=tu_x_password_de_datil_aqui

# Supabase (migración de datos — proyecto "mandarina-DATA")
# Backend de datos: "sheets" (actual, producción) o "supabase" (nuevo). Empezar en sheets.
DATA_BACKEND=sheets
SUPABASE_URL=https://piingkecjgoisnxccvaa.supabase.co
# anon/publishable key (pública, segura de exponer)
SUPABASE_ANON_KEY=sb_publishable_79yw-rYm6C1qmIsST9PLxA_HQRFuUcU
# service_role SECRET (server-side ONLY, ignora RLS). Sácala de:
# Supabase -> mandarina-DATA -> Project Settings -> API -> service_role secret.
# NUNCA con prefijo NEXT_PUBLIC_ ni subir a git.
SUPABASE_SERVICE_ROLE_KEY=pega-aqui-la-service-role-secret

# App
NEXTAUTH_SECRET=genera-un-secret-largo-aqui
NEXT_PUBLIC_APP_URL=https://mandarina-pro.vercel.app

# Anthropic (Hoodie Prompt Generator — /hoodie-prompt)
# La usa /api/analyze-image para describir los diseños subidos. Solo server-side.
# Se genera en https://console.anthropic.com -> API Keys. Ponla tambien en Vercel.
ANTHROPIC_API_KEY=sk-ant-...

# Meta Conversions API (envio directo, reemplaza el webhook de Make)
# Con estas 3 variables el CRM manda el evento Purchase DIRECTO a Meta cada vez
# que se crea un pedido. Si falta META_CAPI_TOKEN, sigue usando el webhook de
# Make como antes (asi la migracion se activa y se revierte sin desplegar).
#
# META_CAPI_TOKEN: Events Manager -> el dataset -> Configuracion -> Conversions API
#   -> "Generar token de acceso". Es un secreto: solo en Vercel, nunca en el repo.
# Los pixel id salen de Events Manager (o de la lista de datasets del negocio):
#   Mandarina = PixelFinalMandarinaRepublic
#   Indstore  = IND WEB
# Nota: las ventas de YAW se contabilizan en el pixel de Mandarina, igual que
# hacia el escenario de Make.
META_CAPI_TOKEN=
META_PIXEL_MANDARINA=612911870044679
META_PIXEL_INDSTORE=1520595899347453

# Notificaciones por Telegram (bot API, gratis). UN solo bot para todo el CRM.
# El bot debe estar DENTRO de cada grupo/chat al que quieras avisar.
#
# TELEGRAM_BOT_TOKEN: crea un bot con @BotFather -> te da el token. (O reusa el bot
#   que ya usabas en Make; su token esta en la conexion de Telegram de Make.)
# TELEGRAM_CHAT_VENTAS: chat donde llegan las ventas (cada vez que un vendedor
#   cierra un pedido). Si no la pones, usa el chat que venia de Make (-5103132453).
# TELEGRAM_CHAT_ERRORES: chat de alertas del tablero /dashboard/errores. Opcional:
#   sin esto, los errores igual se guardan en la tabla, solo que no se avisa.
# Para obtener un chat.id: agrega el bot al grupo, manda un mensaje, y abre
#   https://api.telegram.org/bot<TOKEN>/getUpdates -> copia chat.id (negativo en grupos).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_VENTAS=-5103132453
TELEGRAM_CHAT_ERRORES=
